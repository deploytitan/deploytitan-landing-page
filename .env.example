# ── Console & app URLs ────────────────────────────────────────────────────────
NEXT_PUBLIC_CONSOLE_URL=https://console.deploytitan.com
NEXT_PUBLIC_DEMO_URL=https://demo.deploytitan.com
NEXT_PUBLIC_DOCS_URL=https://docs.deploytitan.com

# ── Public site metadata ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://deploytitan.com

# ── HubSpot (waitlist + newsletter) ───────────────────────────────────────────
# Server-only — do NOT prefix with NEXT_PUBLIC_
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PORTAL_ID=
HUBSPOT_WAITLIST_FORM_GUID=
HUBSPOT_NEWSLETTER_FORM_GUID=
NEXT_PUBLIC_NEWSLETTER_PROVIDER=hubspot

# ── Polar.sh billing ─────────────────────────────────────────────────────────
# Server-only — do NOT prefix with NEXT_PUBLIC_
POLAR_ACCESS_TOKEN=polar_oat_...
POLAR_ORG_SLUG=deploytitan

# ── Sanity CMS (blog) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
# SANITY_API_READ_TOKEN=   # server-only — needed for draft mode & revalidate webhook
# SANITY_REVALIDATE_SECRET= # shared secret for the /api/revalidate webhook

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set to "false" to reveal stealth products (Shield, Ledger, Insight, Sandbox)
NEXT_PUBLIC_STEALTH_PRODUCTS=true
